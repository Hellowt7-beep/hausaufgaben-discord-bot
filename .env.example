# Discord Bot Token (aus Discord Developer Portal)
DISCORD_TOKEN=your_discord_bot_token_here

# Gemini API Key (aus Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# MEGA Login Daten
MEGA_EMAIL=your_mega_email_here
MEGA_PASSWORD=your_mega_password_here

# Optional: Kanal ID wo der Bot arbeiten soll (leer lassen für alle Kanäle)
ALLOWED_CHANNEL_ID=
